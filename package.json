{
  "name": "IssieBoard",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "npm run build:keyboards && react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "test:android": "cd android && ./gradlew :app:testDebugUnitTest",
    "test:ios": "cd ios && xcodebuild test -workspace IssieBoardNG.xcworkspace -scheme IssieBoardNG -destination 'platform=iOS Simulator,name=iPhone 17' -quiet",
    "build:dictionaries": "node scripts/build_dictionaries.js",
    "build:keyboards": "node scripts/build_keyboard_configs.js",
    "build:keyboard-neighbors": "node scripts/build_keyboard_neighbors.js",
    "build:all": "npm run build:dictionaries && npm run build:keyboards && npm run build:keyboard-neighbors",
    "open:android-sim": "~/Library/Android/sdk/emulator/emulator -avd Pixel_3a &",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@react-native/new-app-screen": "0.83.1",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/stack": "^7.7.1",
    "js-yaml": "^4.1.1",
    "react": "19.2.0",
    "react-native": "0.83.1",
    "react-native-default-preference": "^1.4.4",
    "react-native-draggable-flatlist": "^4.0.1",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "^3.16.4",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.23.0",
    "react-native-tts": "^4.1.1",
    "react-native-wheel-color-picker": "^1.3.1",
    "rn-emoji-keyboard": "^1.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "^20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.83.1",
    "@react-native/eslint-config": "0.83.1",
    "@react-native/metro-config": "0.83.1",
    "@react-native/typescript-config": "0.83.1",
    "@types/jest": "^29.5.13",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "patch-package": "^8.0.0",
    "prettier": "2.8.8",
    "react-native-asset": "^2.2.8",
    "react-test-renderer": "19.2.0",
    "sharp": "^0.34.5",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
